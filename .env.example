# ============================================================
# POLYMARKET TRADING BOT — ENVIRONMENT CONFIGURATION
# Copy to `.env` and fill in your values. NEVER commit `.env`.
# ============================================================

# --- Trading mode ---
# "paper" = always simulated (zero risk, no wallet required)
# "live"  = always real money on Polygon (requires wallet + API keys)
# "auto"  = automatic — wallet USDC >= AUTO_MODE_MIN_BALANCE_USD trades real,
#           otherwise paper-trades into a separate ledger. SAFE DEFAULT.
TRADING_MODE=auto
AUTO_MODE_MIN_BALANCE_USD=5.00

# --- Bankroll & risk ---
INITIAL_BANKROLL=5.00
MAX_CONCURRENT_BETS=3
KELLY_FRACTION=0.25
MIN_EDGE_THRESHOLD=0.03
MIN_CONFIDENCE=0.65
MAX_POSITION_FRACTION=0.20
STOP_LOSS_FRACTION=0.80
DRAWDOWN_CIRCUIT_BREAKER=0.30

# --- Market filters ---
MIN_LIQUIDITY_USD=5000
MIN_VOLUME_24H_USD=1000
MIN_HOURS_TO_CLOSE=6

# --- Polymarket / Polygon (LIVE mode only) ---
# Generate keys via py-clob-client `create_or_derive_api_creds`
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
PRIVATE_KEY=
POLYGON_RPC_URL=https://polygon-rpc.com
CLOB_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com
CHAIN_ID=137

# --- Probability oracles ---
# Kalshi: public endpoint (NO AUTH). Despite the "elections" subdomain
# it serves every Kalshi market.
KALSHI_API=https://api.elections.kalshi.com/trade-api/v2
# Metaculus: requires an account + API token. Leave blank to skip this
# source. Generate at https://www.metaculus.com/accounts/profile/
METACULUS_API=https://www.metaculus.com/api
METACULUS_TOKEN=

# --- Scheduler ---
SCAN_INTERVAL_SECONDS=60
ORDER_TIMEOUT_SECONDS=300
WEBSOCKET_HEARTBEAT_SECONDS=5

# --- Database ---
DATABASE_URL=sqlite:///./data/polybot.db

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
